# ===========================================
# ClipFlow Backend — Environment Variables
# ===========================================
# Bu dosyayı .env olarak kopyala ve değerleri doldur:
#   cp .env.example .env
# ===========================================

# --- Storage ---
STORAGE_PATH=/tmp/clipflow

# Cloudflare R2 (V2 — boş bırakırsan local storage kullanılır)
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=clipflow

# --- AI Services ---
# OpenAI Whisper API (ileride altyazı için)
WHISPER_API_KEY=

# --- Processing ---
MAX_UPLOAD_SIZE_MB=500
FFMPEG_PRESET=fast
SILENCE_THRESHOLD_DB=-30
MIN_SILENCE_DURATION=0.3
MAX_CONCURRENT_JOBS=3
PROCESSING_TIMEOUT=600

# --- Push Notifications (APNs) ---
# Apple Developer'dan indirdiğin .p8 dosyasının yolu
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
