# ClipFlow Environment Variables
# Copy to .env and fill in values

# Storage (V1: local, V2: R2)
STORAGE_PATH=/tmp/clipflow
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=clipflow

# AI Services
WHISPER_API_KEY=

# Processing
MAX_UPLOAD_SIZE_MB=500
FFMPEG_PRESET=fast
SILENCE_THRESHOLD_DB=-30
MIN_SILENCE_DURATION=0.3
MAX_CONCURRENT_JOBS=3

# Push Notifications (iOS)
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
